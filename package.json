  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.3.1"
  },
  "dependencies": {
    "phaser": "4.0.0",
    "terser": "^5.39.0"
  }
}
